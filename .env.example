# Configuración de ejemplo para Nutri-Fit. Copia a `.env` (que está gitignored).
# Las claves de IA son OPCIONALES aquí: la app puede enviar la suya por request
# desde la pantalla de Ajustes de IA. Estas sirven como defaults del backend.

# --- Proveedores cloud (opcional) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Servidores de IA locales del host (opcional) ---
# Usa host.docker.internal para que el contenedor backend alcance el host.
LMSTUDIO_URL=http://host.docker.internal:1234/v1
VLLM_URL=http://host.docker.internal:8000/v1

# --- Ollama (ya en el docker-compose) ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1

# Referencia de proveedores soportados por la capa de IA (F8):
#   openai      -> https://api.openai.com/v1                 (OPENAI_API_KEY)
#   openrouter  -> https://openrouter.ai/api/v1              (clave de OpenRouter)
#   gemini      -> https://generativelanguage.googleapis.com/v1beta/openai/  (clave de Google AI)
#   lmstudio    -> LMSTUDIO_URL                              (token dummy)
#   vllm        -> VLLM_URL                                  (token dummy)
#   ollama      -> $OLLAMA_HOST/v1                           (token dummy)
#   claude      -> SDK anthropic nativo                      (ANTHROPIC_API_KEY)
