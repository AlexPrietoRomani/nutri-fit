# ==========================================
# Nutri-Fit Git Ignore Configuration
# ==========================================

# --- OS Globals ---
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# --- Environment & Credentials ---
.env
.env.*
!.env.example

# --- Python / Backend ---
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
pytest.ini
.tox/
.coverage
.mypy_cache/
htmlcov/
build/
dist/
*.egg-info/
.eggs/
nosetests.xml
coverage.xml
*.cover
pip-log.txt
pip-delete-this-directory.txt

# Backend specific paths
backend/venv/
backend/env/
backend/.venv/
backend/.pytest_cache/
backend/htmlcov/
backend/.coverage
backend/.tox/
backend/.mypy_cache/
backend/build/
backend/dist/
backend/*.egg-info/
backend/.eggs/
backend/lib/
backend/lib64/
backend/var/
backend/parts/

# --- Global Web & JS Patterns ---
# (Aplica a todas las subcarpetas como frontend/)
node_modules/
dist/
.astro/
.npm
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Rust ---
# (Aplica a todas las subcarpetas como active_learning_worker/)
target/
debug/
release/
*.rs.bk

# --- IDE & Editors ---
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.settings/
.classpath

